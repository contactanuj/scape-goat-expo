{
  "name": "scape-goat",
  "version": "1.0.0",
  "description": "Unofficial, non-commercial pass-and-play adaptation of the hidden-role heist game Scape Goat (Expo + WebView). Configurable, with honest computer players.",
  "keywords": [
    "expo",
    "react-native",
    "board-game",
    "party-game",
    "social-deduction",
    "hidden-role",
    "pass-and-play"
  ],
  "author": "Anuj Pratap Singh",
  "license": "MIT",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "build:html": "node build.js",
    "icon": "node make-icon.js",
    "test": "node tests/engine.test.js && node tests/ui.smoke.test.js",
    "start": "npm run build:html && expo start",
    "android": "npm run build:html && expo run:android",
    "ios": "npm run build:html && expo run:ios",
    "build:android": "npm run build:html && npx eas-cli build -p android --profile preview"
  },
  "dependencies": {
    "babel-preset-expo": "~54.0.10",
    "expo": "^54.0.35",
    "expo-asset": "~12.0.13",
    "expo-file-system": "~19.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0"
  }
}
