# Copy to .env (which is gitignored) or set these in your CI provider's secrets.
# NEVER commit real tokens.

# Expo access token, used by EAS builds / the GitHub Actions build workflow.
# Create one at https://expo.dev/accounts/[account]/settings/access-tokens
# In GitHub: add it as a repository secret named EXPO_TOKEN.
EXPO_TOKEN=your-expo-access-token-here
